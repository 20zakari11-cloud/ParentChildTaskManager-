<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ParentChildTaskManager">

        <activity
            android:name=".ui.role.RoleSelectionActivity"
            android:exported="true"
            android:screenOrientation="portrait">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <activity
            android:name=".ui.mother.MotherDashboardActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.mother.AddTaskActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.mother.ChildProgressActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.child.ChildHomeActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.child.BedtimeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:showWhenLocked="true"
            android:turnScreenOn="true" />
        <activity
    android:name=".ui.overlay.TaskOverlayActivity"
    android:exported="false"
    android:showWhenLocked="true"
    android:turnScreenOn="true"
    android:excludeFromRecents="true"
    android:launchMode="singleTask" />

        <receiver
            android:name=".utils.SnoozeReceiver"
            android:exported="false" />

        <receiver
            android:name=".utils.BedtimeReceiver"
            android:exported="false" />

        <service
            android:name=".utils.BedtimeService"
            android:exported="false" />

        <!-- Firebase Cloud Messaging (جاهز للتفعيل لاحقاً)
        <service
            android:name=".utils.FCMService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        -->

    </application>

</manifest>
