<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_child">

    <!-- Top bar: character + stats -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@color/child_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvCharacterEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🐣"
            android:textSize="36sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المبتدئ الشجاع"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:alpha="0.85" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tvStars"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 0"
                    android:textSize="16sp"
                    android:textColor="@color/star_color"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tvLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lv.1"
                    android:textSize="14sp"
                    android:textColor="@color/white" />

            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressLevel"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progressDrawable="@drawable/progress_bar_child"
                android:max="100"
                android:progress="0"
                android:layout_marginTop="6dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- No task state -->
    <TextView
        android:id="@+id/tvNoTask"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎉\n\nأحسنت!\nلا توجد مهام الآن.\nاستمتع بوقتك!"
        android:textSize="22sp"
        android:textColor="@color/child_primary"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Task card (big, centered) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTask"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/btnCompleteTask"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.4">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 مهمتك الآن"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvTaskTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvTaskDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:gravity="center" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Snooze timer (shown while snoozed) -->
    <LinearLayout
        android:id="@+id/layoutSnoozeTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/btnCompleteTask"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💤 المهمة مؤجلة"
            android:textSize="16sp"
            android:textColor="@color/status_snoozed" />

        <TextView
            android:id="@+id/tvSnoozeTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:00"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/child_primary"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Complete button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCompleteTask"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="✅  أنجزت المهمة!"
        android:textSize="18sp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="8dp"
        app:backgroundTint="@color/status_completed"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toTopOf="@id/btnSnooze"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Snooze button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSnooze"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="💤  تأجيل 10 دقائق (مرة واحدة)"
        android:textSize="14sp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="8dp"
        app:strokeColor="@color/child_primary"
        android:textColor="@color/child_primary"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toTopOf="@id/btnSwitchRole"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSwitchRole"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="تبديل المستخدم"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
